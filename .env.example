# PostgreSQL connection string
# Example: postgresql://user:password@host:5432/techhive
DATABASE_URL=postgresql://change-me:change-me@localhost:5432/techhive

# OpenRouter API key — get yours at https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-key-here

# AI Provider: openrouter | groq | openai (default: openrouter)
# AI_PROVIDER=groq

# Model override (optional — uses provider default if not set)
# AI_MODEL=llama-3.3-70b-versatile

# Groq API key — console.groq.com (free, better rate limits than OpenRouter)
# GROQ_API_KEY=gsk_your-groq-key-here

# OpenAI API key — platform.openai.com (paid, no rate limits, gpt-4o-mini recommended)
# OPENAI_API_KEY=sk-your-openai-key-here

# Base URL (used in server-side fetch calls in admin page)
# In production, set to your Netlify URL: https://your-app.netlify.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin credentials (for authentication)
# ADMIN_PASSWORD_B64 = base64 of your password (node -e "console.log(Buffer.from('yourpassword').toString('base64'))")
ADMIN_EMAIL=admin@techhive.app
ADMIN_PASSWORD_B64=change-me-base64-encoded-password

# Session secret (min 32 chars for HS256)
SESSION_SECRET=change-me-32-chars-minimum-secret-key
